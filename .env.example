# Full JID (and password) of the bot/agent's XMPP account.
XMPP_JID=agent@example.com
XMPP_PASSWORD=changeme

# Optional: host:port override if SRV/DNS discovery on the JID's domain
# won't find your server (e.g. self-hosted behind a nonstandard port).
#XMPP_SERVER=example.com:5222

# The human's JID — used as the default recipient for `msg send`.
XMPP_TO=zach@example.com

# Optional: a MUC room to join (`msg listen`) and send to (`msg room`).
# Find it with `msg disco <domain>` (lists the domain's services, e.g.
# muc.example.com), then `msg disco muc.example.com` (lists its rooms).
#XMPP_ROOM=testing@muc.example.com
#XMPP_NICK=agent
